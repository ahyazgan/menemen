# Lezzet proxy ortam değişkenleri (server/proxy.mjs için).
# Gerçek .env dosyası gitignore'dadır — anahtarları yalnızca sunucuda tut.

PORT=8787
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Kimlik doğrulama önceliği: JWKS > RS256(PEM) > HS256 > statik token > dev.
# 1a) JWKS (önerilir, çok anahtar/rotasyon): { "keys": [JWK,...] } JSON'u (tek satır).
LEZZET_JWKS=
# 1b) RS256 tek açık anahtar: PEM (SPKI). Çok satırlıysa \n ile kaçışlayabilirsin.
LEZZET_JWT_PUBLIC_KEY=
# 1c) HS256 paylaşılan sır.
LEZZET_JWT_SECRET=
# 2) Statik token (basit kurulum/dev): izinli Bearer token'lar (virgülle ayır).
LEZZET_PROXY_TOKENS=
# Hepsi boşsa auth KAPALI (yalnızca geliştirme). JWT modlarında rate-limit
# anahtarı token "sub" alanıdır.

# Anahtar (JWT sub / token / IP) başına dakikadaki istek limiti.
RATE_LIMIT_RPM=60
# Uç nokta allowlist'i: yalnızca beklenen method+yol geçer (varsayılan açık).
# Kapatmak için "off" yaz (önerilmez).
LEZZET_ALLOWLIST=on
# İstek gövdesi boyut limiti (bayt). Aşan istek 413 alır. Varsayılan 10 MB.
MAX_BODY_BYTES=10485760
