# Lezzet proxy ortam değişkenleri (server/proxy.mjs için).
# Gerçek .env dosyası gitignore'dadır — anahtarları yalnızca sunucuda tut.

PORT=8787
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Canlı (full-duplex) ses — LiveKit. Doluysa POST /voice-token kısa ömürlü oda
# token'ı imzalar (secret SUNUCUDA kalır, uygulamaya gömülmez). Canlı modun
# çalışması için ayrıca sunucu-taraflı bir AI ajanı odaya katılmalıdır
# (STT→LLM→TTS); bkz. docs/launch-runbook.md. App tarafı: config/LIVEKIT_WS_URL +
# flags.liveVoice.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=

# Kimlik doğrulama önceliği: JWKS_URL > JWKS > RS256(PEM) > HS256 > statik token > dev.
# 0) Uzaktan JWKS (önerilir): kimlik sağlayıcının jwks.json adresi (önbellekli).
LEZZET_JWKS_URL=
LEZZET_JWKS_TTL_MS=3600000
# 1a) Inline JWKS: { "keys": [JWK,...] } JSON'u (tek satır).
LEZZET_JWKS=
# 1b) RS256 tek açık anahtar: PEM (SPKI). Çok satırlıysa \n ile kaçışlayabilirsin.
LEZZET_JWT_PUBLIC_KEY=
# 1c) HS256 paylaşılan sır.
LEZZET_JWT_SECRET=
# 2) Statik token (basit kurulum/dev): izinli Bearer token'lar (virgülle ayır).
LEZZET_PROXY_TOKENS=
# Hepsi boşsa auth KAPALI (yalnızca geliştirme). JWT modlarında rate-limit
# anahtarı token "sub" alanıdır.

# Anahtar (JWT sub / token / IP) başına dakikadaki istek limiti.
RATE_LIMIT_RPM=60
# Uç nokta allowlist'i: yalnızca beklenen method+yol geçer (varsayılan açık).
# Kapatmak için "off" yaz (önerilmez).
LEZZET_ALLOWLIST=on
# İstek gövdesi boyut limiti (bayt). Aşan istek 413 alır. Varsayılan 10 MB.
MAX_BODY_BYTES=10485760
