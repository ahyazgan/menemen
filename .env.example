# Lezzet proxy ortam değişkenleri (server/proxy.mjs için).
# Gerçek .env dosyası gitignore'dadır — anahtarları yalnızca sunucuda tut.

PORT=8787
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Kimlik doğrulama önceliği: JWT > statik token > dev (kapalı).
# 1) JWT (önerilir): kimlik sağlayıcının HS256 ile imzaladığı token'ların sırrı.
#    Ayarlıysa Authorization: Bearer <jwt> doğrulanır; rate-limit anahtarı JWT "sub".
LEZZET_JWT_SECRET=
# 2) Statik token (basit kurulum/dev): izinli Bearer token'lar (virgülle ayır).
LEZZET_PROXY_TOKENS=
# İkisi de boşsa auth KAPALI (yalnızca geliştirme).

# Anahtar (JWT sub / token / IP) başına dakikadaki istek limiti.
RATE_LIMIT_RPM=60
# Uç nokta allowlist'i: yalnızca beklenen method+yol geçer (varsayılan açık).
# Kapatmak için "off" yaz (önerilmez).
LEZZET_ALLOWLIST=on
