# Lezzet proxy ortam değişkenleri (server/proxy.mjs için).
# Gerçek .env dosyası gitignore'dadır — anahtarları yalnızca sunucuda tut.

PORT=8787
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# İstemci doğrulaması: izinli Bearer token'lar (virgülle ayır). Boşsa auth KAPALI (dev).
LEZZET_PROXY_TOKENS=
# Anahtar başına dakikadaki istek limiti.
RATE_LIMIT_RPM=60
