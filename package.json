{
  "name": "lezzet",
  "version": "0.1.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "proxy": "node server/proxy.mjs",
    "gen:assets": "node scripts/gen-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:engine": "node scripts/test-engine.mjs",
    "test:server": "node --test server/__tests__/*.test.mjs",
    "test": "npm run typecheck && npm run test:engine && npm run test:server"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-voice/voice": "^3.2.4",
    "expo": "~51.0.0",
    "expo-audio": "~0.3.0",
    "expo-camera": "~15.0.0",
    "expo-image-picker": "~15.0.7",
    "expo-localization": "~15.0.3",
    "expo-notifications": "^0.28.19",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-purchases": "^10.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.8.4",
    "typescript": "~5.3.0"
  },
  "private": true
}
