# Lezzet canlı ses ajanı ortam değişkenleri.
# Gerçek .env yalnızca sunucuda; anahtarları asla uygulamaya/gite koyma.

# LiveKit worker kimliği (proxy ile AYNI proje, ama bunlar ajanın kendi kopyası).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Sağlayıcı anahtarları (yalnızca sunucuda).
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
